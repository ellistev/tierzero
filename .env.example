OPENAI_API_KEY=sk-...

# ServiceNow connector (run / watch commands)
SERVICENOW_INSTANCE_URL=https://mycompany.service-now.com
SERVICENOW_USERNAME=svc-agent
SERVICENOW_PASSWORD=

# Jira connector (use JiraConnector instead of ServiceNowConnector)
JIRA_BASE_URL=https://mycompany.atlassian.net
JIRA_EMAIL=svc-agent@mycompany.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=ITSM

# GitLab connector (use GitLabConnector instead of ServiceNowConnector)
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_PROJECT_ID=mygroup/myproject

# Azure DevOps (import-wiki --source azuredevops, mine-tickets --connector azuredevops)
AZUREDEVOPS_ORG=myorg
AZUREDEVOPS_PROJECT=MyProject
AZUREDEVOPS_TOKEN=

# Confluence (import-wiki --source confluence)
CONFLUENCE_BASE_URL=https://mycompany.atlassian.net
CONFLUENCE_EMAIL=svc-agent@mycompany.com
CONFLUENCE_API_TOKEN=
