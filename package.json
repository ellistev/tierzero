{
  "name": "tierzero",
  "version": "0.1.0",
  "description": "AI agent for IT ticket resolution using RAG and LangGraph",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc",
    "test": "tsx --test src/connectors/servicenow.test.ts src/connectors/jira.test.ts src/rag/retriever.test.ts src/agent/agent.test.ts src/agent/poller.test.ts",
    "test:integration": "tsx test/integration.ts",
    "dev": "tsx src/cli.ts",
    "index": "tsx src/cli.ts index",
    "run-agent": "tsx src/cli.ts run",
    "watch": "tsx src/cli.ts watch"
  },
  "dependencies": {
    "@langchain/community": "^1.1.20",
    "@langchain/core": "^1.1.29",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/openai": "^1.2.11",
    "@langchain/textsplitters": "^1.0.1",
    "chromadb": "^3.3.1",
    "zod": "^3.24.0",
    "dotenv": "^16.4.5",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
